# =============================================
# Lunchloop 環境変数テンプレート
# cp .env.example .env してから値を埋める
# .env は .gitignore 済み（コミット厳禁）
# =============================================

# ─── Database ───────────────────────────────
POSTGRES_USER=lunchloop
POSTGRES_PASSWORD=lunchloop_dev
POSTGRES_DB=lunchloop
DATABASE_URL=postgresql://lunchloop:lunchloop_dev@localhost:5432/lunchloop

# ─── Supabase ───────────────────────────────
# https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── AWS ────────────────────────────────────
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=lunchloop-verification-docs

# ─── Google Maps ────────────────────────────
# https://console.cloud.google.com → Maps Platform
# 必要API: Places API, Distance Matrix API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── App ────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
MATCHING_SERVICE_URL=http://localhost:8000

# ─── JWT / Auth ─────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ─── Expo Push ──────────────────────────────
EXPO_ACCESS_TOKEN=your-expo-access-token
